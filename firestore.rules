rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function getAuthUid() {
      return isSignedIn() ? request.auth.uid : null;
    }
    
    // Helper to check if a user is "mock-authenticated" or real-authenticated
    // This supports the requested "mock user logins" pattern
    function isUser(uid) {
      return (isSignedIn() && request.auth.uid == uid) || (uid.startsWith('mock_'));
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    function hasRole(uid, role) {
      return getUserData(uid).role == role;
    }
    function isAdmin(uid) { return hasRole(uid, 'admin'); }
    function isTeacher(uid) { return hasRole(uid, 'teacher'); }
    function isParent(uid) { return hasRole(uid, 'parent'); }

    match /users/{userId} {
      allow get: if isUser(userId) || (isSignedIn() && (isAdmin(request.auth.uid) || isTeacher(request.auth.uid)));
      allow list: if true; // Relaxed for the requested mock user login demo
      allow create: if isUser(userId); 
      allow update: if isUser(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar_url', 'school_id']);
    }

    match /schools/{schoolId} {
      allow read: if true; // Public view for school info
      allow write: if isSignedIn() && isAdmin(request.auth.uid);
    }

    match /classes/{classId} {
      allow read: if true;
      allow write: if isSignedIn() && (isAdmin(request.auth.uid) || isTeacher(request.auth.uid));
    }

    match /class_students/{id} {
      allow read: if true;
      allow write: if isSignedIn() && (isAdmin(request.auth.uid) || isTeacher(request.auth.uid));
    }

    match /attendance/{id} {
      allow read: if true; // Simplified for demo/mock mode
      allow create, update: if true; // Simplified for demo/mock mode
    }

    match /homework/{id} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /assignments/{id} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /homework_submissions/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    match /assessments/{id} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /assessment_scores/{id} {
      allow read: if true;
      allow create, update: if true;
    }

    match /channels/{id} {
      allow read: if true;
      allow write: if true;
    }

    match /messages/{id} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }

    match /notifications/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }
  }
}
